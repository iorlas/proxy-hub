runtime:
  thread_number: 2

log:
  default: stdout

resolver:
  - name: default
    type: c-ares
    server:
      - 1.1.1.1
      - 8.8.8.8

escaper:
  # Fast free proxies (>= 1 MB/s bandwidth)
  - name: fast-free-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool:free:fast"
    cache: /var/cache/g3proxy/fast-free-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Slow free proxies (< 1 MB/s but YouTube-validated)
  - name: slow-free-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool:free:slow"
    cache: /var/cache/g3proxy/slow-free-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Laptop proxies from health-checker
  - name: laptop-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool"
    cache: /var/cache/g3proxy/laptop-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Tier 2 failover: slow free → laptops
  - name: fallback-chain
    type: route_failover
    primary_next: slow-free-pool
    standby_next: laptop-pool
    fallback_delay: 5s

  # Tier 1 failover: fast free → (slow free → laptops)
  - name: failover
    type: route_failover
    primary_next: fast-free-pool
    standby_next: fallback-chain
    fallback_delay: 5s

server:
  - name: socks-in
    type: socks_proxy
    escaper: failover
    listen:
      address: "0.0.0.0:1080"

  - name: http-in
    type: http_proxy
    escaper: failover
    listen:
      address: "0.0.0.0:8080"
