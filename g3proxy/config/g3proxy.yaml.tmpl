runtime:
  thread_number: 2

log:
  default: stdout

resolver:
  - name: default
    type: c-ares
    server:
      - 1.1.1.1
      - 8.8.8.8

escaper:
  # Fast free proxies (>= 1 MB/s bandwidth)
  - name: fast-free-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool:free:fast"
    cache: /var/cache/g3proxy/fast-free-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Slow free proxies (< 1 MB/s but YouTube-validated)
  - name: slow-free-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool:free:slow"
    cache: /var/cache/g3proxy/slow-free-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Laptop proxies from health-checker
  - name: laptop-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool"
    cache: /var/cache/g3proxy/laptop-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Free-only failover: fast → slow (NO laptop fallback)
  - name: free-only
    type: route_failover
    primary_next: fast-free-pool
    standby_next: slow-free-pool
    fallback_delay: 3500ms

  # Full failover: slow free → laptops
  - name: fallback-chain
    type: route_failover
    primary_next: slow-free-pool
    standby_next: laptop-pool
    fallback_delay: 3500ms

  # Full failover: fast free → (slow free → laptops)
  - name: failover-full
    type: route_failover
    primary_next: fast-free-pool
    standby_next: fallback-chain
    fallback_delay: 3500ms

server:
  # Port 2080/2880: full failover (free → laptops)
  - name: socks-in
    type: socks_proxy
    escaper: failover-full
    listen:
      address: "0.0.0.0:2080"

  - name: http-in
    type: http_proxy
    escaper: failover-full
    listen:
      address: "0.0.0.0:2880"

  # Port 2081/2881: free proxies only (NO laptop fallback)
  - name: socks-free-only
    type: socks_proxy
    escaper: free-only
    listen:
      address: "0.0.0.0:2081"

  - name: http-free-only
    type: http_proxy
    escaper: free-only
    listen:
      address: "0.0.0.0:2881"
