runtime:
  thread_number: 2

log:
  default: stdout

resolver:
  - name: default
    type: c-ares
    server:
      - 1.1.1.1
      - 8.8.8.8

escaper:
  # Free proxies from scanner (proxy_pool:free)
  - name: free-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool:free"
    cache: /var/cache/g3proxy/free-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Laptop proxies from health-checker (proxy_pool)
  - name: laptop-pool
    type: proxy_float
    source: "redis://:${REDIS_PASSWORD}@redis:6379/0?sets_key=proxy_pool"
    cache: /var/cache/g3proxy/laptop-peers.json
    refresh_interval: 5s
    expire_guard_duration: 10s

  # Failover: try free proxies first, fall back to laptops
  - name: failover
    type: route_failover
    primary_next: free-pool
    standby_next: laptop-pool
    fallback_delay: 200ms

server:
  - name: socks-in
    type: socks_proxy
    escaper: failover
    listen:
      address: "0.0.0.0:1080"

  - name: http-in
    type: http_proxy
    escaper: failover
    listen:
      address: "0.0.0.0:8080"
